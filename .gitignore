# OS-generated files
.DS_Store
Thumbs.db

# Editor directories and swap files
.idea/
*.swp
*.swo

# Keep shared VS Code settings opt-in, ignore other local state
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Logs and local temp files
*.log
*.tmp
*.temp

# Local environment files and secrets
.env
.env.*
!.env.example

# Generic caches
.cache/