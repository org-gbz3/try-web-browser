# OS-generated files
.DS_Store
Thumbs.db

# Editor directories and swap files
.idea/
*.swp
*.swo

# Keep shared VS Code settings opt-in, ignore other local state
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Logs and local temp files
*.log
*.tmp
*.temp

# Local environment files and secrets
.env
.env.*
!.env.example

# Generic caches
.cache/

# Python virtual environments
.venv/
venv/
env/

# Python bytecode and cache directories
__pycache__/
*.py[cod]
*$py.class

# Python tooling caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.nox/

# Coverage and test artifacts
.coverage
.coverage.*
htmlcov/

# Packaging artifacts
build/
dist/
*.egg-info/
pip-wheel-metadata/